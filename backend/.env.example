APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

DISPLAY_TIMEZONE=Europe/Berlin

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single,stderr
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mariadb
DB_HOST=127.0.0.1
DB_PORT=3306
# Make sure the variables match the ones set at root/.env
DB_DATABASE=silence # DB_DATABASE
DB_USERNAME=backend # DB_LARAVEL_USER
DB_PASSWORD=backend123 # DB_LARAVEL_PASSWORD

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

OPENSTACK_AUTH_URL=https://api.dc1.ro.cloud.cnds.io:5000

# --- Shibboleth-Authentifizierung ---
# Header-Namen die der Shibboleth SP setzt (Standardwerte passen normalerweise)
SHIB_HEADER_EPPN=eppn
SHIB_HEADER_DISPLAY_NAME=displayName
SHIB_HEADER_MAIL=mail
SHIB_HEADER_AFFILIATION=affiliation
SHIB_HEADER_ENTITLEMENT=entitlement

# Entitlement das RZ-Mitarbeiter besitzen muessen um Zugang zu erhalten
SHIB_REQUIRED_ENTITLEMENT=urn:mace:fh-rosenheim.de:entitlement:rp-RZ-Mitarbeiter

# Shibboleth SP Handler URLs
SHIB_LOGIN_URL=/Shibboleth.sso/Login
SHIB_LOGOUT_URL=/Shibboleth.sso/Logout

# Lokale Entwicklung: Shibboleth-Authentifizierung simulieren (NIEMALS in Produktion!)
SHIB_SIMULATE=true
SHIB_SIMULATE_EPPN=testuser@th-rosenheim.de
SHIB_SIMULATE_DISPLAY_NAME="Max Mustermann (RZ)"
SHIB_SIMULATE_MAIL=testuser@th-rosenheim.de
SHIB_SIMULATE_AFFILIATION=employee@th-rosenheim.de
SHIB_SIMULATE_ENTITLEMENT=urn:mace:fh-rosenheim.de:entitlement:rp-RZ-Mitarbeiter
