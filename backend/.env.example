APP_NAME=Laravel
APP_ENV=local
APP_KEY=
# Comma-separated list of previously used APP_KEYs. On rotation, move the old
# APP_KEY here so existing encrypted data (e.g. server credentials) stays decryptable.
APP_PREVIOUS_KEYS=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

DISPLAY_TIMEZONE=Europe/Berlin

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single,stderr
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mariadb
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=silence
DB_USERNAME=backend
DB_PASSWORD=backend123

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=database

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

SHIB_HEADER_EPPN=eppn
SHIB_HEADER_DISPLAY_NAME=displayName
SHIB_HEADER_MAIL=mail
SHIB_HEADER_AFFILIATION=affiliation
SHIB_HEADER_ENTITLEMENT=entitlement

SHIB_REQUIRED_ENTITLEMENT=urn:mace:fh-rosenheim.de:entitlement:rp-RZ-Mitarbeiter

SHIB_LOGIN_URL=/Shibboleth.sso/Login
SHIB_LOGOUT_URL=/Shibboleth.sso/Logout

SHIB_SIMULATE=true
SHIB_SIMULATE_EPPN=testuser@th-rosenheim.de
SHIB_SIMULATE_DISPLAY_NAME="Max Mustermann (RZ)"
SHIB_SIMULATE_MAIL=testuser@th-rosenheim.de
SHIB_SIMULATE_AFFILIATION=employee@th-rosenheim.de
SHIB_SIMULATE_ENTITLEMENT=urn:mace:fh-rosenheim.de:entitlement:rp-RZ-Mitarbeiter

COST_CPU_RATE_PER_HOUR=0.0138888
COST_RAM_RATE_PER_HOUR=0.0069444
